<html>
  <head>
    <script src="https://aframe.io/releases/1.8.0/aframe.min.js"></script>
  </head>
  <body>
    <a-scene>
      <a-box position="-1 1 -3" rotation="0 0 30" color="#4A0087#"></a-box>
     <a-box position="-1 02 -3" rotation="0 0 30" color="#4A0087#"></a-box>
      <a-box position="-1 03 -3" rotation="0 0 30" color="#4A0087#"></a-box>
      <a-sphere position="0 1 -5" radius="1.25" color="#4AB74D"></a-sphere>
      <a-sphere position="0 2 -5" radius="1.25" color="#4AB74D"></a-sphere>
      <a-sphere position="0 3 -5" radius="1.25" color="#4AB74D"></a-sphere><a-sphere position="0 1 -5" radius="1.25" color="#4AB74D"></a-sphere>
      <a-sphere position="0 4 -5" radius="1.25" color="#4AB74D"></a-sphere>
      <a-sphere position="0 5 -5" radius="1.25" color="#4AB74D"></a-sphere>
      <a-cylinder position="1 1 -3" rotation="0 0 30" radius="0.5" height="2" color="#906CFF"></a-cylinder>
      <a-cylinder position="1 2 -3" rotation="0 0 30" radius="0.5" height="2" color="#906CFF"></a-cylinder>
      <a-cylinder position="1 3 -3" rotation="0 0 30" radius="0.5" height="2" color="#906CFF"></a-cylinder>
      <a-plane position="0 0 -4" rotation="-90 0 0" width="10" height="10" color="#7BC8A4"></a-plane>
      <a-sky color="#90E5FF"></a-sky>
     </a-scene>
  </body>
</html> 